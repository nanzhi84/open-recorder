{
	"name": "@open-recorder/desktop",
	"productName": "Open Recorder",
	"description": "A free, creator-focused screen recorder with auto-zoom, cursor effects, backgrounds, annotations, and more - built for polished videos out of the box.",
	"author": "imbhargav5",
	"homepage": "https://github.com/imbhargav5/open-recorder",
	"repository": {
		"type": "git",
		"url": "https://github.com/imbhargav5/open-recorder.git"
	},
	"bugs": {
		"url": "https://github.com/imbhargav5/open-recorder/issues"
	},
	"private": true,
	"version": "0.0.35",
	"packageManager": "pnpm@10.17.1",
	"type": "module",
	"main": "dist-electron/main.js",
	"scripts": {
		"postinstall": "pnpm node scripts/patch-electron-plist.mjs",
		"dev": "vite",
		"build": "vite build",
		"build:dist": "pnpm build && electron-builder",
		"build:icons": "node scripts/build-icons.mjs",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"i18n:check": "node scripts/i18n-check.mjs",
		"test": "vitest --run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"e2e": "pnpm run e2e:coverage && playwright test --config e2e/playwright.config.ts",
		"e2e:coverage": "node scripts/assert-critical-flow-coverage.mjs",
		"e2e:ui": "playwright test --config e2e/playwright.config.ts --ui"
	},
	"dependencies": {
		"@fix-webm-duration/fix": "^1.0.1",
		"@fix-webm-duration/parser": "^1.0.1",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/resources": "^2.6.0",
		"@opentelemetry/sdk-trace-web": "^2.6.0",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@pixi/filter-drop-shadow": "^5.2.0",
		"@pixi/filter-motion-blur": "^5.1.1",
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slider": "^1.3.6",
		"@radix-ui/react-slot": "^1.2.3",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-toggle": "^1.1.10",
		"@radix-ui/react-toggle-group": "^1.1.11",
		"@types/gif.js": "^0.2.5",
		"@uiw/color-convert": "^2.9.2",
		"@uiw/react-color-block": "^2.9.2",
		"@xstate/react": "^6.1.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dnd-timeline": "^2.2.0",
		"electron-updater": "^6.8.3",
		"emoji-picker-react": "^4.16.1",
		"gif.js": "^0.2.0",
		"gsap": "^3.13.0",
		"jotai": "^2.19.1",
		"lucide-react": "^0.545.0",
		"mediabunny": "^1.25.1",
		"motion": "^12.23.24",
		"mp4box": "^2.2.0",
		"pixi-filters": "^6.1.5",
		"pixi.js": "^8.14.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-icons": "^5.5.0",
		"react-resizable-panels": "^3.0.6",
		"react-rnd": "^10.5.2",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.3.1",
		"uuid": "^13.0.0",
		"web-demuxer": "^4.0.0",
		"xstate": "^5.28.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@playwright/test": "^1.52.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.0.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/uuid": "^10.0.0",
		"@vitejs/plugin-react": "^4.7.0",
		"electron": "^41.2.1",
		"electron-builder": "^26.8.1",
		"fast-check": "^4.5.2",
		"jsdom": "^29.0.1",
		"tailwindcss": "^4.2.2",
		"terser": "^5.44.1",
		"typescript": "^6.0.3",
		"vite": "^5.1.6",
		"vite-plugin-electron": "0.29.1",
		"vitest": "3.2.4"
	}
}
